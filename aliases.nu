alias vim = nvim
alias .j = just --justfile (echo ~/.user.justfile | path expand) --working-directory .
alias l = sorted-ls
alias gemini = /google/bin/releases/gemini-cli/tools/gemini
alias jetski-cli = /google/bin/releases/jetski-devs/tools/cli

# used to be branch build, however now I have a new tool
alias bb = chip-size
